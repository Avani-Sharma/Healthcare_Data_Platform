{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "bigdata-instance-rg"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"AzureSynapseAnalytics1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSynapseAnalytics1'"
		},
		"junestorageregex_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'junestorageregex'"
		},
		"mysql_ls_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'mysql_ls'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://externalregex.dfs.core.windows.net/"
		},
		"AzureSynapseAnalytics1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "bigdata-workspace.sql.azuresynapse.net"
		},
		"AzureSynapseAnalytics1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "avani"
		},
		"AzureSynapseAnalytics1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladminuser"
		},
		"junestorageregex_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://junestoragereg.dfs.core.windows.net/"
		},
		"mysql_ls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "127.0.0.1"
		},
		"mysql_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "healthcare_db"
		},
		"mysql_ls_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "root"
		},
		"hospitalCostReport_Trigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/fa4819a7-c495-4dd8-b805-bab36552a51f/resourceGroups/june-regex/providers/Microsoft.Storage/storageAccounts/junestoragereg"
		},
		"icd_trigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/fa4819a7-c495-4dd8-b805-bab36552a51f/resourceGroups/june-regex/providers/Microsoft.Storage/storageAccounts/junestoragereg"
		},
		"patient_triggers_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/fa4819a7-c495-4dd8-b805-bab36552a51f/resourceGroups/june-regex/providers/Microsoft.Storage/storageAccounts/junestoragereg"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "bigdata-instance-rg_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"AzureSynapseAnalytics1_password": {
						"value": "[parameters('AzureSynapseAnalytics1_password')]"
					},
					"junestorageregex_accountKey": {
						"value": "[parameters('junestorageregex_accountKey')]"
					},
					"mysql_ls_password": {
						"value": "[parameters('mysql_ls_password')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"AzureSynapseAnalytics1_properties_typeProperties_server": {
						"value": "[parameters('AzureSynapseAnalytics1_properties_typeProperties_server')]"
					},
					"AzureSynapseAnalytics1_properties_typeProperties_database": {
						"value": "[parameters('AzureSynapseAnalytics1_properties_typeProperties_database')]"
					},
					"AzureSynapseAnalytics1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSynapseAnalytics1_properties_typeProperties_userName')]"
					},
					"junestorageregex_properties_typeProperties_url": {
						"value": "[parameters('junestorageregex_properties_typeProperties_url')]"
					},
					"hospitalCostReport_Trigger_properties_typeProperties_scope": {
						"value": "[parameters('hospitalCostReport_Trigger_properties_typeProperties_scope')]"
					},
					"mysql_ls_properties_typeProperties_server": {
						"value": "[parameters('mysql_ls_properties_typeProperties_server')]"
					},
					"mysql_ls_properties_typeProperties_database": {
						"value": "[parameters('mysql_ls_properties_typeProperties_database')]"
					},
					"mysql_ls_properties_typeProperties_username": {
						"value": "[parameters('mysql_ls_properties_typeProperties_username')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "bigdata-instance-rg_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"icd_trigger_properties_typeProperties_scope": {
						"value": "[parameters('icd_trigger_properties_typeProperties_scope')]"
					},
					"patient_triggers_properties_typeProperties_scope": {
						"value": "[parameters('patient_triggers_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'bigdata-instance-rg_ArmTemplate_0')]"
			]
		}
	]
}